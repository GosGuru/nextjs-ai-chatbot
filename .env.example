# Public application URL. In Vercel this can be your production domain.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Generate with: openssl rand -base64 32
AUTH_SECRET=****

# AI providers
OPENAI_API_KEY=****
DEEPSEEK_API_KEY=****
AI_GATEWAY_API_KEY=****

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=****

# Storage and persistence
BLOB_READ_WRITE_TOKEN=****

# Runtime database connection.
# Supabase on Vercel: use the Transaction pooler URL on port 6543.
POSTGRES_URL=postgresql://postgres.project-ref:password@aws-region.pooler.supabase.com:6543/postgres
# DATABASE_URL may be used instead of POSTGRES_URL.

# Migration database connection.
# Supabase on Vercel: use the Session pooler URL on port 5432.
MIGRATION_DATABASE_URL=postgresql://postgres.project-ref:password@aws-region.pooler.supabase.com:5432/postgres

# Other providers may expose these legacy/direct migration variables.
# DATABASE_URL_UNPOOLED=postgresql://user:password@direct-host:5432/database
# POSTGRES_URL_NON_POOLING=postgresql://user:password@direct-host:5432/database

REDIS_URL=redis://localhost:6379
