# Public application URL. In Vercel this can be your production domain.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Generate with: openssl rand -base64 32
AUTH_SECRET=****

# AI providers
OPENAI_API_KEY=****
DEEPSEEK_API_KEY=****
AI_GATEWAY_API_KEY=****

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=****

# Storage and persistence
BLOB_READ_WRITE_TOKEN=****

# Runtime database connection: configure either POSTGRES_URL or DATABASE_URL.
POSTGRES_URL=postgresql://user:password@pooled-host:5432/database
# DATABASE_URL=postgresql://user:password@pooled-host:5432/database

# Direct database connection for migrations when your provider exposes one.
# Neon commonly provides DATABASE_URL_UNPOOLED; Vercel Postgres may provide POSTGRES_URL_NON_POOLING.
# DATABASE_URL_UNPOOLED=postgresql://user:password@direct-host:5432/database
# POSTGRES_URL_NON_POOLING=postgresql://user:password@direct-host:5432/database

REDIS_URL=redis://localhost:6379
