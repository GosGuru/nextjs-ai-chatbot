# Public application URL. In Vercel this can be your production domain.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Generate with: openssl rand -base64 32
AUTH_SECRET=****

# Required outside Vercel. Vercel deployments can use AI Gateway OIDC.
AI_GATEWAY_API_KEY=****

# Storage and persistence
BLOB_READ_WRITE_TOKEN=****
POSTGRES_URL=****
REDIS_URL=****
